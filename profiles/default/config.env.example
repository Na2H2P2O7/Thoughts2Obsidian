# 随想记录员 · profile 配置示例
# 复制为同目录下的 config.env 并填入你自己的值：
#   cp config.env.example config.env
# dispatcher 走 openclaw.json 的 pluginConfig；本文件供 CLI / 兜底 agent 使用。

# Telegram 随想群 chat_id（负数，例如 -1001234567890）
SUIXIANG_CHAT_ID="<YOUR_TELEGRAM_CHAT_ID>"

# Obsidian / FastNote 目标文件夹
SUIXIANG_FOLDER="Thoughts"

# 日期切换 + HH:MM 时间戳所用时区
SUIXIANG_TZ="America/New_York"

# append_thought.py 路径（部署位置；$HOME 会在 bash 中展开）
APPEND_SCRIPT="$HOME/.openclaw/workspace/skills/suixiang/scripts/append_thought.py"

# 写前对 FastNote sqlite 做一次性备份
FAST_NOTE_ENABLE_SQLITE_BACKUP="1"
